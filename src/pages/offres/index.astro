---
import Layout from '../../layouts/Layout.astro';
import OffreCard from '../../components/OffreCard.astro';

import { getOffres, filterByPrix } from '../../js/backend.mjs';

let Offres = await getOffres();
let message = '';

if (Astro.request.method === "POST") {
    const data = await Astro.request.formData();
    const minPrix = parseInt(data.get("minPrix") as string ?? "0");
    const maxPrix = parseInt(data.get("maxPrix") as string ?? "0");

    if (minPrix > 0 && maxPrix > 0 && maxPrix > minPrix) {
        Offres = await filterByPrix(minPrix, maxPrix);
        if (Offres.length === 0) {
            message = `Pas d'offres entre ${minPrix}€ et ${maxPrix}€`;
        } else {
            message = `Liste des offres entre ${minPrix}€ et ${maxPrix}€`;
        }
    } else {
        message = "Veuillez entrer des valeurs valides pour le prix.";
    }
} else {
    Offres = await getOffres();
}
---

<Layout titre="Offres">
    <p>Découvrez notre sélection de propriétés disponibles.</p>
    
    <a href="/offres/add" class="inline-block px-4 py-2 bg-blue-500 text-white rounded font-bold hover:bg-blue-600 mb-4">Ajouter une offre</a>
    
    <form action="/offres" method="POST" class="mb-4 p-4 bg-gray-100 rounded">
        <input type="number" name="minPrix" placeholder="Prix minimum" class="p-2 border rounded mr-2" />
        <input type="number" name="maxPrix" placeholder="Prix maximum" class="p-2 border rounded mr-2" />
        <input type="submit" value="Filtrer par prix" class="px-4 py-2 bg-green-500 text-white rounded hover:bg-green-600" />
    </form>
    
    {message && <p class="p-2 bg-blue-100 border border-blue-400 text-blue-700 rounded mb-4">{message}</p>}
    
    <div class="filters-container">
        <a href="/offres/surface/80" class="surface-link">Voir les maisons de plus de 80m²</a>
        <a href="/offres/prix/3000" class="price-link">Voir les maisons à moins de 3000€</a>
    </div>
    
    <button id="favori-button" class="bg-pink-300 rounded-lg text-gray-800 font-bold p-2 border" style="border: 2px solid #f59e0b;">Afficher les favoris</button>
    <div class="grid grid-cols-3 gap-4">
        {
            Offres.map(offre => (
                <div class="offre" data-favori={offre.favori.toString()}>
                    <OffreCard offre={offre} />
                </div>
            ))
        }
    </div>
</Layout>

<style>
    .filters-container {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }
    
    .surface-link, .price-link {
        display: inline-block;
        padding: 0.5rem 1rem;
        color: white;
        text-decoration: none;
        border-radius: 0.375rem;
        transition: background-color 0.3s;
    }
    
    .surface-link {
        background-color: #10b981;
    }
    
    .surface-link:hover {
        background-color: #059669;
    }
    
    .price-link {
        background-color: #f59e0b;
    }
    
    .price-link:hover {
        background-color: #d97706;
    }
</style>

<script>
    const button = document.getElementById('favori-button') as HTMLElement;
    let showOnlyFavorites = false;
    
    button?.addEventListener('click', () => {
        showOnlyFavorites = !showOnlyFavorites;
        const offres = document.querySelectorAll('.offre') as NodeListOf<HTMLElement>;
        
        offres.forEach(offre => {
            const isFavori = (offre as HTMLElement).dataset.favori === 'true';
            
            if (showOnlyFavorites) {
                (offre as HTMLElement).style.display = isFavori ? 'block' : 'none';
                button.textContent = 'Afficher tout';
            } else {
                (offre as HTMLElement).style.display = 'block';
                button.textContent = 'Afficher les favoris';
            }
        });
    });
</script>